<?xml version="1.0" encoding="UTF-8"?>
<module_registry xmlns="http://obinexus.com/schema/modules">
    <!-- Feature A: Core functionality -->
    <feature id="A" name="core">
        <component-subset id="1" name="essential">
            <module id="001" name="context">
                <library>
                    <static>modules/feature-A/component-subset-1/module-name-001.a</static>
                    <shared>modules/feature-A/component-subset-1/module-name-001.so</shared>
                    <windows>modules/feature-A/component-subset-1/module-name-001.dll</windows>
                </library>
                <dependencies/>
            </module>
            <module id="002" name="memory">
                <library>
                    <static>modules/feature-A/component-subset-1/module-name-002.a</static>
                    <shared>modules/feature-A/component-subset-1/module-name-002.so</shared>
                </library>
                <dependencies>
                    <dependency>feature-A/component-subset-1/module-name-001</dependency>
                </dependencies>
            </module>
        </component-subset>
    </feature>
    
    <!-- Feature B: Adapter system -->
    <feature id="B" name="adapter">
        <component-subset id="1" name="ffi">
            <module id="003" name="ffi-bridge">
                <library>
                    <static>modules/feature-B/component-subset-1/module-name-003.a</static>
                    <shared>modules/feature-B/component-subset-1/module-name-003.so</shared>
                </library>
                <dependencies>
                    <dependency>feature-A/component-subset-1/module-name-001</dependency>
                </dependencies>
            </module>
        </component-subset>
    </feature>
</module_registry>
